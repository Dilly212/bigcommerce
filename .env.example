# Add one block per store. CODE is the key passed to registerStore / all API calls.
# Any <CODE>_BIGCOMMERCE_STORE_HASH + <CODE>_BIGCOMMERCE_CLIENT_ACCESS_TOKEN pair
# is auto-loaded at startup.

B2B_BIGCOMMERCE_STORE_HASH=
B2B_BIGCOMMERCE_CLIENT_ACCESS_TOKEN=

B2C_BIGCOMMERCE_STORE_HASH=
B2C_BIGCOMMERCE_CLIENT_ACCESS_TOKEN=

VAP_BIGCOMMERCE_STORE_HASH=
VAP_BIGCOMMERCE_CLIENT_ACCESS_TOKEN=

PCH_BIGCOMMERCE_STORE_HASH=
PCH_BIGCOMMERCE_CLIENT_ACCESS_TOKEN=
